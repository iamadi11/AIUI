{
  "name": "@aiui/runtime-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "default": "./src/index.tsx"
    },
    "./bundled": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "@aiui/runtime-core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@aiui/dsl-schema": "workspace:*",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4"
  },
  "scripts": {
    "lint": "echo \"no lint yet\"",
    "build": "vite build --config vite.lib.config.ts",
    "bundle:check": "pnpm run build && node ./scripts/check-bundle-size.mjs"
  }
}
