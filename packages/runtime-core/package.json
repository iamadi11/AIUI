{
  "name": "@aiui/runtime-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./bundled": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "@aiui/dsl-schema": "workspace:*",
    "@aiui/layout-engine": "workspace:*",
    "@aiui/logic": "workspace:*",
    "@aiui/registry": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "happy-dom": "^20.0.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "lint": "echo \"no lint yet\"",
    "build": "vite build --config vite.lib.config.ts",
    "bundle:check": "pnpm run build && node ./scripts/check-bundle-size.mjs",
    "test": "vitest run"
  }
}
