{
  "name": "aiui",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "bundle:check": "pnpm --filter @aiui/runtime-core run bundle:check && pnpm --filter @aiui/runtime-react run bundle:check",
    "dev": "pnpm --filter web dev",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  }
}
